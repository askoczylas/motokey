#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp LEFT    &lt 1 UP
                &kp DOWN      &kp RIGHT
            >;
        };

        service_layer {
            bindings = <
                &none  &none
                &bt BT_CLR      &none
            >;
        };
    };
};
