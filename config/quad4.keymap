#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>

/ {
    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
                &kp LEFT    &kp UP
                &kp DOWN      &kp RIGHT
            >;
        };

        service_layer {
            bindings = <
                &bt BT_CLR  &none
                &none       &none
            >;
        };
    };
};
